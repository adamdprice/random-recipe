# HubSpot API (required)
HUBSPOT_ACCESS_TOKEN=

# Custom object type IDs
# Staff Members - default from N8N workflow
HUBSPOT_STAFF_OBJECT_ID=2-194632537
# Lead Teams - provide your HubSpot custom object type ID when available
HUBSPOT_LEAD_TEAM_OBJECT_ID=2-194633413/

# Optional: pipeline stage for "new" leads (from N8N: new-stage-id)
HUBSPOT_LEAD_PIPELINE_STAGE=new-stage-id

# Re-Distribute tab: use your real HubSpot pipeline/stage IDs (placeholder values cause 400 from API)
# REDISTRIBUTE_LEAD_PIPELINE_ID=your-lead-pipeline-id
# REDISTRIBUTE_UNQUALIFIED_STAGE_ID=your-unqualified-stage-id
# REDISTRIBUTE_NEW_STAGE_ID=stage-id-to-move-leads-to-after-redistribute

# Background lead distribution (periodic refresh every 6 min). Set to false on staging so only production runs it.
# ENABLE_BACKGROUND_DISTRIBUTION=true   (default; use on production)
# ENABLE_BACKGROUND_DISTRIBUTION=false  (use on staging)

# Optional: if set, webhook POST /api/webhooks/lead-team-max-leads must send this in
# X-Webhook-Secret header or ?secret= query (for HubSpot workflow / external callers)
# WEBHOOK_SECRET=

# Optional: login. Set SESSION_SECRET and at least one method (password and/or email code).
# SESSION_SECRET=  a long random string (e.g. openssl rand -hex 32)
# APP_PASSWORD_HASH=  bcrypt hash (see README) for password sign-in

# Optional: passwordless sign-in (one-time code to email). Set SMTP_* and EMAIL_FROM.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@yourdomain.com
# ALLOWED_EMAILS=adam@thegrowtharchitect.co.uk  (comma-separated; only these can request a code)
